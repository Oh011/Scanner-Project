# AI-VulScanner Environment Variables
# Copy this file to .env and fill in your actual values

# OWASP ZAP Configuration
ZAP_API_KEY=your-zap-api-key-here
ZAP_PROXY_HOST=127.0.0.1
ZAP_PROXY_PORT=8081

# OWASP Benchmark Configuration
BENCHMARK_HOST=localhost
BENCHMARK_PORT=8443
BENCHMARK_PROTOCOL=https
